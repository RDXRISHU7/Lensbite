{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a comprehensive user health profile within the Lens Bite application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the user profile, matches Firebase Auth UID."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "healthReport": {
          "type": "string",
          "description": "A structured JSON string containing allergens, medical history, body metrics, and cooking practices."
        }
      },
      "required": [
        "id",
        "email"
      ]
    },
    "SafetyScan": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SafetyScan",
      "type": "object",
      "description": "Represents a saved food safety analysis record.",
      "properties": {
        "productName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "riskScore": { "type": "number" },
        "isSafe": { "type": "boolean" },
        "summary": { "type": "string" },
        "novaScore": { "type": "number" },
        "nutriScore": { "type": "string" },
        "ingredients": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["productName", "timestamp", "riskScore", "isSafe"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "Stores detailed user profile information."
        }
      },
      {
        "path": "/users/{userId}/scans/{scanId}",
        "definition": {
          "entityName": "SafetyScan",
          "schema": { "$ref": "#/backend/entities/SafetyScan" },
          "description": "Stores individual food safety scan history for the user."
        }
      }
    ],
    "reasoning": "Sub-collections for scans allow for efficient querying of history without bloating the main profile document."
  }
}
