/**
 * Core Philosophy: This ruleset enforces a strict user-ownership model. All data is considered private and is
 * only accessible by the authenticated user who created it. There is no concept of public data or shared
 * access in this model.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for reusable logic
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Validates that a new UserProfile has the correct, immutable owner ID.
     * We allow anonymous users to create profiles without requiring an email match
     * since they don't have emails in their auth token.
     */
    function hasValidProfileDataOnCreate(userId) {
      let data = request.resource.data;
      return data.id == userId;
    }

    /**
     * Enforces immutability of the UserProfile's ID on update.
     * Prevents re-assigning the profile to a different user.
     */
    function isUpdatingAllowedFields() {
      let data = request.resource.data;
      return data.id == resource.data.id;
    }

    /**
     * @description Manages a user's own profile document.
     * @path /users/{userId}
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; 
      allow create: if isOwner(userId) && hasValidProfileDataOnCreate(userId);
      allow update: if isOwner(userId) && isUpdatingAllowedFields();
      allow delete: if false; 
    }
  }
}
